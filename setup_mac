#!/bin/bash

set -euo pipefail

red_echo() {
    echo ""
    echo -e "\x1b[1;31m $1\e[0m"
    echo ""
}

link_config() {
    local name="$1"
    local src="$(pwd)/.config/$name"
    local dest="$HOME/.config/$name"

    mkdir -p "$HOME/.config"

    if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
        return
    fi

    if [ -e "$dest" ] || [ -L "$dest" ]; then
        mv "$dest" "$dest.backup-$(date +%Y%m%d%H%M%S)"
    fi

    ln -s "$src" "$dest"
}

backup_legacy_aerospace_config() {
    local legacy="$HOME/.aerospace.toml"

    if [ -e "$legacy" ] || [ -L "$legacy" ]; then
        mv "$legacy" "$legacy.backup-$(date +%Y%m%d%H%M%S)"
    fi
}

#### ----------- setup dotfiles ---------

red_echo "initializing dot files"
git submodule init
git submodule update
link_config fish
link_config nvim
link_config alacritty
link_config ghostty
link_config tmux
backup_legacy_aerospace_config
link_config aerospace

#### --------- homebrew --------------

if ! command -v brew >/dev/null 2>&1; then
    red_echo "installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

red_echo "updating homebrew"
brew update

#### --------- git config --------------

red_echo "configuring git"
git config --global user.name "aniketfuryrocks"
git config --global user.email "contact@aniketprajapati.me"
git config --global core.editor "nvim"
git config --global init.defaultBranch main
git config --global credential.helper store
git config --global gpg.ssh.program "$(pwd)/bin/git-ssh-keygen-keychain"
git config --list

#### --------- install tools ---------

red_echo "installing apps and fonts"
brew install --cask ghostty alacritty neovide-app orbstack markedit font-fira-code-nerd-font

red_echo "installing terminal utils"
brew install neovim neovide fish fzf gh git lazygit lazydocker pinentry-mac yazi go tmux wget

red_echo "installing modern cli tools"
brew install starship eza ripgrep fd bat topgrade miniserve gnu-tar

red_echo "installing compilers and build tools"
brew install ruby llvm gcc cmake meson mold openssl@3 zig

#### --------- MarkEdit extensions ---------

red_echo "installing MarkEdit extensions"
markedit_scripts_dir="$HOME/Library/Containers/app.cyan.markedit/Data/Documents/scripts"
mkdir -p "$markedit_scripts_dir"
curl -fsSL "https://raw.githubusercontent.com/MarkEdit-app/MarkEdit-preview/main/dist/markedit-preview.js" \
    -o "$markedit_scripts_dir/markedit-preview.js"
curl -fsSL "https://raw.githubusercontent.com/MarkEdit-app/MarkEdit-ai-writer/main/dist/markedit-ai-writer.js" \
    -o "$markedit_scripts_dir/markedit-ai-writer.js"

#### --------- shell ---------

red_echo "changing default shell to fish"
fish_path="$(brew --prefix)/bin/fish"
if ! grep -qx "$fish_path" /etc/shells; then
    echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
fi
chsh -s "$fish_path" "$USER"

red_echo "installing omf"
omf_install=$(mktemp)
curl -fsSL https://raw.githubusercontent.com/oh-my-fish/oh-my-fish/master/bin/install -o "$omf_install"
fish "$omf_install" --noninteractive
rm "$omf_install"

red_echo "installing omf plugins"
fish -c 'omf install bass fzf nvm z'

#### --------- imp languages ---------

red_echo "installing rust"
if ! command -v rustup >/dev/null 2>&1; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi
mkdir -p "$HOME/.cargo"
cp ./config.toml "$HOME/.cargo/config.toml"

red_echo "installing nvm"
curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.1/install.sh | bash
fish -c 'nvm install node'

red_echo "installing bun"
curl -fsSL https://bun.sh/install | bash

#### ------------ rust tools ------------

red_echo "installing rust tools"
fish -c 'cargo install cargo-expand cargo-edit cargo-update cargo-watch --locked'
